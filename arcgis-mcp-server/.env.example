# ArcGIS: one of the following (first match wins). See README Authentication.
# 1) Profile (uses .arcgisprofile + keyring)
# ARCGIS_PROFILE=myprofile
# 2) URL + username/password (built-in, LDAP, AD)
# ARCGIS_URL=https://your-org.maps.arcgis.com
# ARCGIS_USERNAME=your_username
# ARCGIS_PASSWORD=your_password
# 3) PKI (PEM key + cert)
# ARCGIS_KEY_FILE=/path/to/key.pem
# ARCGIS_CERT_FILE=/path/to/cert.pem
# 4) PKI (PFX)
# ARCGIS_CERT_FILE=/path/to/cert.pfx
# ARCGIS_CERT_PASSWORD=secret
# 5) IWA (URL only; Windows auth when available)
# ARCGIS_URL=https://portal.domain.com/webadaptor
# 6) ArcGIS Pro (active portal)
# ARCGIS_USE_PRO=1
# 7) Per-user OAuth (Okta SSO): set client id; use get_arcgis_login_url tool or GET /auth/login, then set_arcgis_token with the token
# ARCGIS_CLIENT_ID=your_oauth_client_id
# ARCGIS_CLIENT_SECRET=optional_for_code_exchange
# Base URL for login link (e.g. ngrok): used by get_arcgis_login_url when the agent asks for a sign-in URL
# ARCGIS_AUTH_BASE_URL=https://your-ngrok.ngrok-free.app

# Base URL for shareable map links: when set, show_map returns map_url so users can open the map in a browser (e.g. when the client does not show the in-chat map). Use your server’s public URL (e.g. ngrok) with no trailing slash. If unset, ARCGIS_AUTH_BASE_URL is used when present.
# ARCGIS_MAP_BASE_URL=https://your-ngrok.ngrok-free.app

# Optional: TTL for short map share links (/map/s/<state_id>) in seconds (default 7 days).
# ARCGIS_MAP_STATE_TTL_SECONDS=604800

# Optional: API key for basemaps/location services in the map viewer (GET /map). If vector basemaps or some services require an API key, set it here; it is injected into the standalone map page only.
# ARCGIS_API_KEY=your-arcgis-api-key

# Optional: directions language code for route directions (e.g. en, es, fr). Uses portal default if unset.
# ARCGIS_DIRECTIONS_LANGUAGE=en

# Optional: route solve start time. Default is "now" for traffic-aware routing. Set to a millisecond timestamp or leave unset.
# ARCGIS_ROUTE_START_TIME=now

# Optional: max stops per simple route (default 25). Larger runs may require async routing.
# ARCGIS_MAX_ROUTE_STOPS=25

# Optional: require Bearer token for MCP endpoint
# MCP_API_KEY=your-secret-key

# Optional: use stateless MCP (no session id). Set to 1 when using clients that do not send Mcp-Session-Id (e.g. Trimble AI) so token is stored as pending and used for all requests.
# ARCGIS_MCP_STATELESS=1

# Server
# PORT=3000
